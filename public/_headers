# Cloudflare Pages headers.
# https://developers.cloudflare.com/pages/configuration/headers/

# Content-hashed build assets never change for a given URL — cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Everything else (notably index.html) must be revalidated so new deploys
# are picked up immediately. Add baseline security headers site-wide.
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
